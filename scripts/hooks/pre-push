#!/bin/sh
# pre-push — cross-OS vet gate. The CI windows leg is the product; this
# catches its compile breaks (unix-only types in untagged files) BEFORE the
# push instead of 10 minutes after. Install once per clone:
#   git config core.hooksPath scripts/hooks
# Bypass in an emergency with: git push --no-verify
set -e
cd "$(git rev-parse --show-toplevel)"
pkgs=$(go list ./... | grep -v /external/)
for os in windows linux; do
  echo "pre-push: GOOS=$os go vet (CI scope)" >&2
  GOOS=$os go vet $pkgs
done
